{
  "openapi": "3.0.3",
  "info": {
    "title": "Clubs & Events API",
    "version": "1.0.0",
    "description": "API para gestión de clubes, miembros y eventos"
  },
  "servers": [
    { "url": "/api/v1", "description": "Local" }
  ],
  "tags": [
    { "name": "Clubs" },
    { "name": "Club Members" },
    { "name": "Club Events" },
    { "name": "Events" }
  ],
  "paths": {

    "/clubs": {
      "get": {
        "tags": ["Clubs"],
        "summary": "Listar clubes",
        "parameters": [
          { "$ref": "#/components/parameters/page" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/search" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": {
              "allOf": [
                { "$ref": "#/components/schemas/Paginated" },
                { "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Club" } } } }
              ]
            }}}
          }
        }
      },
      "post": {
        "tags": ["Clubs"],
        "summary": "Crear club",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClubInput" } } }
        },
        "responses": {
          "201": {
            "description": "Club creado",
            "content": { "application/json": { "schema": {
              "properties": {
                "data": { "$ref": "#/components/schemas/Club" },
                "message": { "type": "string", "example": "Club created successfully" }
              }
            }}}
          },
          "400": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },

    "/clubs/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/id" }],
      "get": {
        "tags": ["Clubs"],
        "summary": "Obtener club por ID",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": {
            "properties": { "data": { "$ref": "#/components/schemas/Club" } }
          }}}},
          "404": { "$ref": "#/components/responses/ClubNotFound" }
        }
      },
      "put": {
        "tags": ["Clubs"],
        "summary": "Actualizar club (COALESCE)",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClubInput" } } }
        },
        "responses": {
          "200": { "description": "Actualizado", "content": { "application/json": { "schema": {
            "properties": {
              "data": { "$ref": "#/components/schemas/Club" },
              "message": { "type": "string", "example": "Club updated successfully" }
            }
          }}}},
          "404": { "$ref": "#/components/responses/ClubNotFound" }
        }
      },
      "delete": {
        "tags": ["Clubs"],
        "summary": "Eliminar club",
        "responses": {
          "200": { "description": "Eliminado", "content": { "application/json": { "schema": {
            "properties": {
              "message": { "type": "string", "example": "Club deleted successfully" },
              "deleted_id": { "type": "integer", "example": 1 }
            }
          }}}},
          "404": { "$ref": "#/components/responses/ClubNotFound" }
        }
      }
    },

    "/clubs/{id}/members": {
      "parameters": [{ "$ref": "#/components/parameters/id" }],
      "get": {
        "tags": ["Club Members"],
        "summary": "Listar miembros del club",
        "parameters": [
          { "$ref": "#/components/parameters/page" },
          { "$ref": "#/components/parameters/limit" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": {
            "allOf": [
              { "$ref": "#/components/schemas/Paginated" },
              { "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ClubMember" } } } }
            ]
          }}}},
          "404": { "$ref": "#/components/responses/ClubNotFound" }
        }
      },
      "post": {
        "tags": ["Club Members"],
        "summary": "Asignar miembro existente al club",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "required": ["id_member"],
            "properties": { "id_member": { "type": "integer", "example": 5 } }
          }}}
        },
        "responses": {
          "201": { "description": "Asignado", "content": { "application/json": { "schema": {
            "properties": {
              "data": { "$ref": "#/components/schemas/ClubMember" },
              "message": { "type": "string", "example": "Member assigned to club successfully" }
            }
          }}}},
          "404": { "$ref": "#/components/responses/ClubNotFound" },
          "409": {
            "description": "Miembro ya asignado",
            "content": { "application/json": { "schema": {
              "properties": {
                "error": { "type": "string", "example": "Member already assigned to this club" },
                "code":  { "type": "string", "example": "MEMBER_ALREADY_ASSIGNED" }
              }
            }}}
          }
        }
      }
    },

    "/clubs/{id}/members/create-and-assign": {
      "parameters": [{ "$ref": "#/components/parameters/id" }],
      "post": {
        "tags": ["Club Members"],
        "summary": "Crear miembro nuevo y asignarlo al club (transacción)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "required": ["name", "lastname"],
            "properties": {
              "name":     { "type": "string", "example": "Ana" },
              "lastname": { "type": "string", "example": "López" }
            }
          }}}
        },
        "responses": {
          "201": { "description": "Creado y asignado", "content": { "application/json": { "schema": {
            "properties": {
              "data": {
                "properties": {
                  "member":     { "$ref": "#/components/schemas/Member" },
                  "assignment": { "$ref": "#/components/schemas/ClubMember" }
                }
              },
              "message": { "type": "string", "example": "Member created and assigned to club successfully" }
            }
          }}}},
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/ClubNotFound" }
        }
      }
    },

    "/clubs/{id}/members/{memberId}": {
      "parameters": [
        { "$ref": "#/components/parameters/id" },
        { "name": "memberId", "in": "path", "required": true, "schema": { "type": "integer" } }
      ],
      "delete": {
        "tags": ["Club Members"],
        "summary": "Remover miembro del club",
        "responses": {
          "200": { "description": "Removido", "content": { "application/json": { "schema": {
            "properties": { "message": { "type": "string", "example": "Member removed from club successfully" } }
          }}}},
          "404": { "description": "Relación no encontrada" }
        }
      }
    },

    "/clubs/{id}/events": {
      "parameters": [{ "$ref": "#/components/parameters/id" }],
      "get": {
        "tags": ["Club Events"],
        "summary": "Listar eventos de un club",
        "parameters": [
          { "name": "upcoming", "in": "query", "schema": { "type": "boolean" }, "description": "Solo eventos futuros (datetime > NOW())" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": {
            "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Event" } } }
          }}}},
          "404": { "$ref": "#/components/responses/ClubNotFound" }
        }
      }
    },

    "/events": {
      "get": {
        "tags": ["Events"],
        "summary": "Listar eventos",
        "parameters": [
          { "$ref": "#/components/parameters/page" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/search" },
          { "name": "id_club",  "in": "query", "schema": { "type": "integer" }, "description": "Filtrar por club" },
          { "name": "upcoming", "in": "query", "schema": { "type": "boolean" }, "description": "Solo eventos futuros" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": {
            "allOf": [
              { "$ref": "#/components/schemas/Paginated" },
              { "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Event" } } } }
            ]
          }}}}
        }
      },
      "post": {
        "tags": ["Events"],
        "summary": "Crear evento",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EventInput" } } }
        },
        "responses": {
          "201": { "description": "Creado", "content": { "application/json": { "schema": {
            "properties": {
              "data": { "$ref": "#/components/schemas/Event" },
              "message": { "type": "string", "example": "Event created successfully" }
            }
          }}}},
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/ClubNotFound" }
        }
      }
    },

    "/events/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/id" }],
      "get": {
        "tags": ["Events"],
        "summary": "Obtener evento por ID",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": {
            "properties": { "data": { "$ref": "#/components/schemas/Event" } }
          }}}},
          "404": { "$ref": "#/components/responses/EventNotFound" }
        }
      },
      "put": {
        "tags": ["Events"],
        "summary": "Actualizar evento (COALESCE)",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EventInput" } } }
        },
        "responses": {
          "200": { "description": "Actualizado", "content": { "application/json": { "schema": {
            "properties": {
              "data": { "$ref": "#/components/schemas/Event" },
              "message": { "type": "string", "example": "Event updated successfully" }
            }
          }}}},
          "404": { "$ref": "#/components/responses/EventNotFound" }
        }
      },
      "delete": {
        "tags": ["Events"],
        "summary": "Eliminar evento",
        "responses": {
          "200": { "description": "Eliminado", "content": { "application/json": { "schema": {
            "properties": {
              "message": { "type": "string", "example": "Event deleted successfully" },
              "deleted_id": { "type": "integer", "example": 1 }
            }
          }}}},
          "404": { "$ref": "#/components/responses/EventNotFound" }
        }
      }
    }

  },

  "components": {
    "parameters": {
      "id":     { "name": "id",     "in": "path",  "required": true, "schema": { "type": "integer" } },
      "page":   { "name": "page",   "in": "query", "schema": { "type": "integer", "default": 1 } },
      "limit":  { "name": "limit",  "in": "query", "schema": { "type": "integer", "default": 10 } },
      "search": { "name": "search", "in": "query", "schema": { "type": "string" } }
    },
    "schemas": {
      "Member": {
        "properties": {
          "id":         { "type": "integer" },
          "name":       { "type": "string" },
          "lastname":   { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Club": {
        "properties": {
          "id":           { "type": "integer" },
          "name":         { "type": "string" },
          "description":  { "type": "string", "nullable": true },
          "schedule":     { "type": "string", "nullable": true },
          "location":     { "type": "string", "nullable": true },
          "created_at":   { "type": "string", "format": "date-time" },
          "member_count": { "type": "integer" }
        }
      },
      "ClubInput": {
        "required": ["name", "description", "schedule", "location"],
        "properties": {
          "name":        { "type": "string", "maxLength": 150 },
          "description": { "type": "string", "maxLength": 500 },
          "schedule":    { "type": "string", "maxLength": 100 },
          "location":    { "type": "string", "maxLength": 150 }
        }
      },
      "ClubMember": {
        "properties": {
          "id_member":   { "type": "integer" },
          "id_club":     { "type": "integer" },
          "date_assign": { "type": "string", "format": "date-time" },
          "member": {
            "properties": {
              "id":       { "type": "integer" },
              "name":     { "type": "string" },
              "lastname": { "type": "string" }
            }
          }
        }
      },
      "Event": {
        "properties": {
          "id":                   { "type": "integer" },
          "id_club":              { "type": "integer" },
          "name":                 { "type": "string" },
          "description":          { "type": "string", "nullable": true },
          "datetime":             { "type": "string", "format": "date-time" },
          "location":             { "type": "string", "nullable": true },
          "max_participants":     { "type": "integer" },
          "current_participants": { "type": "integer" },
          "created_at":           { "type": "string", "format": "date-time" },
          "club": {
            "properties": {
              "id":   { "type": "integer" },
              "name": { "type": "string" }
            }
          }
        }
      },
      "EventInput": {
        "required": ["id_club", "name", "datetime", "location", "max_participants"],
        "properties": {
          "id_club":          { "type": "integer" },
          "name":             { "type": "string" },
          "description":      { "type": "string", "nullable": true },
          "datetime":         { "type": "string", "format": "date-time" },
          "location":         { "type": "string" },
          "max_participants": { "type": "integer" }
        }
      },
      "Paginated": {
        "properties": {
          "total":       { "type": "integer" },
          "page":        { "type": "integer" },
          "limit":       { "type": "integer" },
          "total_pages": { "type": "integer" }
        }
      }
    },
    "responses": {
      "ValidationError": {
        "description": "Error de validación",
        "content": { "application/json": { "schema": {
          "properties": {
            "error":   { "type": "string", "example": "Validation error" },
            "code":    { "type": "string", "example": "VALIDATION_ERROR" },
            "details": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        }}}
      },
      "ClubNotFound": {
        "description": "Club no encontrado",
        "content": { "application/json": { "schema": {
          "properties": {
            "error": { "type": "string", "example": "Club not found" },
            "code":  { "type": "string", "example": "CLUB_NOT_FOUND" }
          }
        }}}
      },
      "EventNotFound": {
        "description": "Evento no encontrado",
        "content": { "application/json": { "schema": {
          "properties": {
            "error": { "type": "string", "example": "Event not found" },
            "code":  { "type": "string", "example": "EVENT_NOT_FOUND" }
          }
        }}}
      }
    }
  }
}
